---
import '../styles/twitch.scss';
import GlobalLayout from '../layouts/GlobalLayout.astro';
import HeadingCard from '../components/HeadingCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SectionContainer from '../components/SectionContainer.astro';
import OnAir from '../react-components/OnAir.tsx';
import NowPlaying from '../react-components/NowPlaying.tsx';
import LatestVod from '../react-components/LatestVod.tsx';
import PopularClipsList from '../react-components/PopularClipsList.tsx';
import Mainframe from '../react-components/Mainframe.tsx';


---

<GlobalLayout
	title="Twitch | the13thgeek&trade;" 
	section="twitch"
	path={Astro.url.pathname}>
	<SectionContainer>	
		<HeadingCard>
			<SectionHeading isStyled={false} headingType="h1" sectionNumber={1}>
				Twitch
			</SectionHeading>
			<p class="subtitle">Live. Chill. Game. Repeat.</p>
		</HeadingCard>
	</SectionContainer>
	<SectionContainer className='twitch-struct'>
		<SectionHeading isStyled={true} headingType="h2" sectionNumber={2}>
			On Air
		</SectionHeading>
		<OnAir client:load />
	</SectionContainer>
	<SectionContainer className='twitch-nowplaying'>
		<SectionHeading isStyled={true} headingType="h2" sectionNumber={2}>
			Now Playing
		</SectionHeading>
		<NowPlaying client:load />
	</SectionContainer>
	<SectionContainer className='clips' noTopMargin>
		<div class="box vod">
			<SectionHeading isStyled={true} headingType="h2" sectionNumber={3}>
				Latest VOD
			</SectionHeading>
			<LatestVod client:load />
		</div>
		<div class="box clips">
			<SectionHeading isStyled={true} headingType="h2" sectionNumber={4}>
				Popular Clips
			</SectionHeading>
			<PopularClipsList client:load />
		</div>
	</SectionContainer>
	<SectionContainer className='mainframe' noTopMargin  ctaText='Open the Mainframe' ctaHref='https://mainframe.the13thgeek.com/'>
		<SectionHeading isStyled={true} headingType="h2" slot="heading" sectionNumber={5}>The Mainframe</SectionHeading>
		<Mainframe client:load />
	</SectionContainer>
</GlobalLayout>